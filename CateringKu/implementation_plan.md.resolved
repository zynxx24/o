### Routes

#### [MODIFY] `routes/web.php`
```php
// Customer
Route::get('/wallet', [WalletController::class, 'index'])
Route::post('/wallet/withdraw', [WalletController::class, 'requestWithdrawal'])
Route::get('/become-vendor', [VendorApplicationController::class, 'create'])
Route::post('/become-vendor', [VendorApplicationController::class, 'store'])
Route::get('/become-vendor/status', [VendorApplicationController::class, 'status'])

// Admin
Route::prefix('admin')->group(function() {
    Route::get('/wallets', ...)
    Route::get('/withdrawals', ...)
    Route::patch('/withdrawals/{id}/approve', ...)
    Route::patch('/withdrawals/{id}/reject', ...)
    Route::get('/vendor-applications', ...)
    Route::patch('/vendor-applications/{id}/approve', ...)
    Route::patch('/vendor-applications/{id}/reject', ...)
    Route::get('/commissions', ...)         // dashboard komisi
    Route::get('/commission-rules', ...)   // edit aturan %
    Route::patch('/commission-rules', ...)
})
```

